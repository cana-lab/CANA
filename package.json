{
  "name": "cana",
  "private": true,
  "version": "4.26.0",
  "type": "module",
  "description": "A private, local-first biblical life-planning tool for couples. Runs in a desktop browser and talks directly to a local Ollama LLM. No data leaves your machine.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173/cana/ && CANA_DEV_URL=http://localhost:5173/cana/ electron .\"",
    "build:electron": "BUILD_TARGET=electron vite build",
    "predist:mac": "npm run build:electron && node scripts/prepare-electron.cjs",
    "dist:mac": "electron-builder --mac",
    "pack:mac": "npm run predist:mac && npm run dist:mac"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.cana.covenantlife",
    "productName": "CANA",
    "copyright": "Copyright \u00a9 2026",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.lifestyle",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "darkModeSupport": false
    },
    "dmg": {
      "title": "CANA \u2014 Covenant Life",
      "icon": "build/icon.icns",
      "window": {
        "width": 540,
        "height": 380
      },
      "iconSize": 110,
      "contents": [
        {
          "x": 140,
          "y": 180,
          "type": "file"
        },
        {
          "x": 400,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}