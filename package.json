{
  "name": "cana",
  "private": true,
  "version": "4.46.1",
  "type": "module",
  "description": "A private, local-first biblical life-planning tool for couples. Runs in a desktop browser and talks directly to a local Ollama LLM. No data leaves your machine.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173/cana/ && CANA_DEV_URL=http://localhost:5173/cana/ electron .\"",
    "build:electron": "BUILD_TARGET=electron vite build",
    "predist:mac": "node scripts/sync-versions.cjs && npm run build:electron && node scripts/prepare-electron.cjs",
    "dist:mac": "electron-builder --mac",
    "pack:mac": "npm run predist:mac && npm run dist:mac",
    "prebuild:ios": "node scripts/sync-versions.cjs",
    "build:ios": "BUILD_TARGET=ios vite build",
    "ios:sync": "npm run build:ios && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:bump-build": "node scripts/sync-versions.cjs --bump-build",
    "versions:check": "node scripts/sync-versions.cjs --check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@electron/notarize": "^2.5.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^42.4.0",
    "electron-builder": "^24.13.3",
    "jsdom": "^29.1.1",
    "vite": "^5.4.0",
    "vitest": "^4.1.8",
    "wait-on": "^7.2.0"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.cana.covenantlife",
    "productName": "CANA",
    "copyright": "Copyright © 2026",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [],
    "publish": [
      {
        "provider": "github",
        "owner": "cana-lab",
        "repo": "CANA"
      }
    ],
    "mac": {
      "category": "public.app-category.lifestyle",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "darkModeSupport": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "CANA — Covenant Life",
      "icon": "build/icon.icns",
      "window": {
        "width": 540,
        "height": 380
      },
      "iconSize": 110,
      "contents": [
        {
          "x": 140,
          "y": 180,
          "type": "file"
        },
        {
          "x": 400,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "afterSign": "scripts/notarize.cjs"
  }
}
