node_modules/
dist/
dist-ios/
dist-ssr/
*.local
.DS_Store
.vscode/
*.log
npm-debug.log*
.env
.env.*

# Electron build artifacts (regenerated by the packaging script)
/electron/renderer/
/release/

# Capacitor native iOS project: the whole ios/ folder IS committed (source of
# truth for Xcode build settings, Info.plist, signing config, the
# PrivacyInfo.xcprivacy manifest, etc.). What we exclude below is either
# regenerated by `pod install` / `npx cap sync ios`, or per-user / per-machine.
ios/App/Pods/
ios/App/App/public/
ios/App/build/
ios/DerivedData/
**/xcuserdata/
**/*.xcuserstate
